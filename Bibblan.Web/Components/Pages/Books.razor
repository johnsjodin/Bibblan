@page "/books"
@using Bibblan.Data.Entities
@using Bibblan.Data.Repositories
@inject IBookRepository BookRepository
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Böcker - Bibblan</PageTitle>

<h1>📖 Böcker</h1>

<div class="row mb-3">
    <div class="col-md-6">
        <div class="input-group">
            <input type="text" class="form-control" placeholder="Sök på titel, författare eller ISBN..."
                   @bind="_searchTerm" @bind:event="oninput" @onkeyup="HandleSearch" />
            <button class="btn btn-outline-secondary" type="button" @onclick="SearchBooks">
                🔍 Sök
            </button>
            @if (!string.IsNullOrEmpty(_searchTerm))
            {
                <button class="btn btn-outline-danger" type="button" @onclick="ClearSearch">
                    ✕
                </button>
            }
        </div>
    </div>
    <div class="col-md-6 text-end">
        <button class="btn btn-primary" @onclick="ShowAddBookModal">
            ➕ Lägg till bok
        </button>
    </div>
</div>

@if (_isLoading)
{
    <div class="d-flex justify-content-center my-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Laddar...</span>
        </div>
    </div>
}
else if (_books == null || !_books.Any())
{
    <div class="alert alert-info">
        @if (string.IsNullOrEmpty(_searchTerm))
        {
            <span>Inga böcker finns i katalogen. Lägg till din första bok!</span>
        }
        else
        {
            <span>Inga böcker matchade sökningen "@_searchTerm".</span>
        }
    </div>
}
else
{
    <p class="text-muted">Visar @_books.Count() böcker</p>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th @onclick="() => SortBy(SortColumn.Title)" style="cursor: pointer">
                    Titel @GetSortIndicator(SortColumn.Title)
                </th>
                <th @onclick="() => SortBy(SortColumn.Author)" style="cursor: pointer">
                    Författare @GetSortIndicator(SortColumn.Author)
                </th>
                <th>ISBN</th>
                <th @onclick="() => SortBy(SortColumn.Year)" style="cursor: pointer">
                    År @GetSortIndicator(SortColumn.Year)
                </th>
                <th>Status</th>
                <th>Åtgärder</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in _sortedBooks)
            {
                <tr>
                    <td>@book.Title</td>
                    <td>@book.Author</td>
                    <td><code>@book.ISBN</code></td>
                    <td>@book.PublishedYear</td>
                    <td>
                        @if (book.IsAvailable)
                        {
                            @if (book.IsReserved)
                            {
                                <span class="badge bg-warning">Reserverad</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Tillgänglig</span>
                            }
                        }
                        else
                        {
                            @if (book.IsReserved)
                            {
                                <span class="badge bg-danger">Utlånad (Reserverad)</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Utlånad</span>
                            }
                        }
                    </td>
                    <td>
                        <a href="books/@book.Id" class="btn btn-sm btn-outline-primary">Detaljer</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_showAddModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Lägg till ny bok</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <EditForm Model="@_newBook" OnValidSubmit="HandleAddBook">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <div class="alert alert-danger">@_errorMessage</div>
                        }
                        <div class="mb-3">
                            <label class="form-label">ISBN</label>
                            <InputText @bind-Value="_newBook.ISBN" class="form-control" />
                            <ValidationMessage For="@(() => _newBook.ISBN)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Titel</label>
                            <InputText @bind-Value="_newBook.Title" class="form-control" />
                            <ValidationMessage For="@(() => _newBook.Title)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Författare</label>
                            <InputText @bind-Value="_newBook.Author" class="form-control" />
                            <ValidationMessage For="@(() => _newBook.Author)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Utgivningsår</label>
                            <InputNumber @bind-Value="_newBook.PublishedYear" class="form-control" />
                            <ValidationMessage For="@(() => _newBook.PublishedYear)" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseModal">Avbryt</button>
                        <button type="submit" class="btn btn-primary">Spara</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private IEnumerable<BookEntity> _books = new List<BookEntity>();
    private IEnumerable<BookEntity> _sortedBooks => ApplySorting();
    private bool _isLoading = true;
    private string _searchTerm = string.Empty;
    private bool _showAddModal = false;
    private BookEntity _newBook = new();
    private string _errorMessage = string.Empty;

    private SortColumn _sortColumn = SortColumn.Title;
    private bool _sortAscending = true;

    private enum SortColumn { Title, Author, Year }

    protected override async Task OnInitializedAsync()
    {
        await LoadBooks();
    }

    private async Task LoadBooks()
    {
        _isLoading = true;
        try
        {
            _books = string.IsNullOrWhiteSpace(_searchTerm)
                ? await BookRepository.GetAllAsync()
                : await BookRepository.SearchAsync(_searchTerm);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchBooks();
        }
    }

    private async Task SearchBooks()
    {
        await LoadBooks();
    }

    private async Task ClearSearch()
    {
        _searchTerm = string.Empty;
        await LoadBooks();
    }

    private void SortBy(SortColumn column)
    {
        if (_sortColumn == column)
        {
            _sortAscending = !_sortAscending;
        }
        else
        {
            _sortColumn = column;
            _sortAscending = true;
        }
    }

    private IEnumerable<BookEntity> ApplySorting()
    {
        return _sortColumn switch
        {
            SortColumn.Title => _sortAscending ? _books.OrderBy(b => b.Title) : _books.OrderByDescending(b => b.Title),
            SortColumn.Author => _sortAscending ? _books.OrderBy(b => b.Author) : _books.OrderByDescending(b => b.Author),
            SortColumn.Year => _sortAscending ? _books.OrderBy(b => b.PublishedYear) : _books.OrderByDescending(b => b.PublishedYear),
            _ => _books
        };
    }

    private string GetSortIndicator(SortColumn column)
    {
        if (_sortColumn != column) return "";
        return _sortAscending ? "▲" : "▼";
    }

    private void ShowAddBookModal()
    {
        _newBook = new BookEntity { PublishedYear = DateTime.Now.Year };
        _errorMessage = string.Empty;
        _showAddModal = true;
    }

    private void CloseModal()
    {
        _showAddModal = false;
        _errorMessage = string.Empty;
    }

    private async Task HandleAddBook()
    {
        try
        {
            // Validera att ISBN inte redan finns
            var existing = await BookRepository.GetByISBNAsync(_newBook.ISBN);
            if (existing != null)
            {
                _errorMessage = "En bok med detta ISBN finns redan.";
                return;
            }

            _newBook.IsAvailable = true;
            await BookRepository.AddAsync(_newBook);
            await LoadBooks();
            CloseModal();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fel vid sparning: {ex.Message}";
        }
    }
}
