@page "/books"
@using Bibblan.Data.Entities
@using Bibblan.Data.Repositories
@using Bibblan.Web.Components.Shared
@inject IBookRepository BookRepository
@rendermode InteractiveServer

<PageTitle>Böcker - Bibblan</PageTitle>

<h1>📖 Böcker</h1>

<div class="row mb-3">
    <div class="col-12 col-md-6 mb-2 mb-md-0">
        <div class="input-group">
            <input type="text" class="form-control" placeholder="Sök på titel, författare eller ISBN..."
                   @bind="_searchTerm" @bind:event="oninput" @onkeyup="HandleSearch" />
            <button class="btn btn-outline-secondary" type="button" @onclick="SearchBooks">
                🔍 Sök
            </button>
            @if (!string.IsNullOrEmpty(_searchTerm))
            {
                <button class="btn btn-outline-danger" type="button" @onclick="ClearSearch">
                    ✕
                </button>
            }
        </div>
    </div>
    <div class="col-12 col-md-6 text-md-end">
        <button class="btn btn-primary w-100 w-md-auto" @onclick="ShowAddBookModal">
            ➕ Lägg till bok
        </button>
    </div>
</div>

@if (_isLoading)
{
    <div class="d-flex justify-content-center my-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Laddar...</span>
        </div>
    </div>
}
else if (_books == null || !_books.Any())
{
    <div class="alert alert-info">
        @if (string.IsNullOrEmpty(_searchTerm))
        {
            <span>Inga böcker finns i katalogen. Lägg till din första bok!</span>
        }
        else
        {
            <span>Inga böcker matchade sökningen "@_searchTerm".</span>
        }
    </div>
}
else
{
    <p class="text-muted">Visar @_books.Count() böcker</p>

    <div class="row">
        @foreach (var book in _books)
        {
            <div class="col-12 col-sm-6 col-lg-4 mb-3">
                <BookCard Book="book" />
            </div>
        }
    </div>
}

@if (_showAddModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Lägg till ny bok</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <EditForm Model="@_newBook" OnValidSubmit="HandleAddBook">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <div class="alert alert-danger">@_errorMessage</div>
                        }
                        <div class="mb-3">
                            <label class="form-label">ISBN</label>
                            <InputText @bind-Value="_newBook.ISBN" class="form-control" />
                            <ValidationMessage For="@(() => _newBook.ISBN)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Titel</label>
                            <InputText @bind-Value="_newBook.Title" class="form-control" />
                            <ValidationMessage For="@(() => _newBook.Title)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Författare</label>
                            <InputText @bind-Value="_newBook.Author" class="form-control" />
                            <ValidationMessage For="@(() => _newBook.Author)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Utgivningsår</label>
                            <InputNumber @bind-Value="_newBook.PublishedYear" class="form-control" 
                                         max="@DateTime.Now.Year" min="1450" />
                            <ValidationMessage For="@(() => _newBook.PublishedYear)" />
                            <small class="text-muted">Max: @DateTime.Now.Year</small>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseModal">Avbryt</button>
                        <button type="submit" class="btn btn-primary">Spara</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private IEnumerable<BookEntity> _books = new List<BookEntity>();
    private bool _isLoading = true;
    private string _searchTerm = string.Empty;
    private bool _showAddModal = false;
    private BookEntity _newBook = new();
    private string _errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadBooks();
    }

    private async Task LoadBooks()
    {
        _isLoading = true;
        try
        {
            _books = string.IsNullOrWhiteSpace(_searchTerm)
                ? await BookRepository.GetAllAsync()
                : await BookRepository.SearchAsync(_searchTerm);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchBooks();
        }
    }

    private async Task SearchBooks()
    {
        await LoadBooks();
    }

    private async Task ClearSearch()
    {
        _searchTerm = string.Empty;
        await LoadBooks();
    }

    private void ShowAddBookModal()
    {
        _newBook = new BookEntity { PublishedYear = DateTime.Now.Year };
        _errorMessage = string.Empty;
        _showAddModal = true;
    }

    private void CloseModal()
    {
        _showAddModal = false;
        _errorMessage = string.Empty;
    }

    private async Task HandleAddBook()
    {
        try
        {
            // Validera att ISBN inte redan finns
            var existing = await BookRepository.GetByISBNAsync(_newBook.ISBN);
            if (existing != null)
            {
                _errorMessage = "En bok med detta ISBN finns redan.";
                return;
            }

            _newBook.IsAvailable = true;
            await BookRepository.AddAsync(_newBook);
            await LoadBooks();
            CloseModal();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fel vid sparning: {ex.Message}";
        }
    }
}
